generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum LeadStatus {
  NEW
  CONTACTED
  RESPONDED
  FOLLOW_UP_1
  FOLLOW_UP_2
  MEETING_SCHEDULED
  PROPOSAL_SENT
  WON
  LOST
  ARCHIVED
}

enum LeadTemperature {
  HOT
  WARM
  COLD
  UNKNOWN
}

enum MessageType {
  INITIAL
  FOLLOW_UP_1
  FOLLOW_UP_2
  CUSTOM
}

enum MessageChannel {
  INSTAGRAM
  WHATSAPP
  LINKEDIN
  EMAIL
  OTHER
}

enum MessageStatus {
  DRAFT
  USED
  SENT
  RESPONDED
  IGNORED
}

enum FollowUpStatus {
  PENDING
  DONE
  CANCELED
  OVERDUE
}

enum FeedbackProblemType {
  INVENTED_INFO
  GENERIC_MESSAGE
  BAD_CLASSIFICATION
  BAD_STRATEGY
  BAD_FORMATTING
  GOOD_RESULT
  OTHER
}

enum LossReason {
  SEM_VERBA
  SEM_INTERESSE
  JA_POSSUI_SISTEMA
  SEM_RESPOSTA
  ADIADO
  OUTRO
}

enum ConversationChannel {
  INSTAGRAM
  WHATSAPP
  EMAIL
  LINKEDIN
  OTHER
}

enum ConversationDirection {
  SENT
  RECEIVED
}

model Lead {
  id               String          @id @default(cuid())
  companyName      String
  instagram        String?         @unique
  website          String?
  niche            String?
  preferredChannel String?
  source           String?         @default("manual")
  notes            String?
  status           LeadStatus      @default(NEW)
  temperature      LeadTemperature @default(UNKNOWN)
  score            Int?            @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  analyses      LeadAnalysis[]
  messages      MessageSuggestion[]
  followups     FollowUpTask[]
  feedbacks     AgentFeedback[]
  outcome       LeadOutcome?
  conversations LeadConversation[]

  @@map("leads")
}

model LeadAnalysis {
  id                  String   @id @default(cuid())
  leadId              String
  lead                Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  classification      String?
  executiveSummary    String?
  commercialDiagnosis String?
  confirmedInfo       Json?    @default("[]")
  observations        Json?    @default("[]")
  hypotheses          Json?    @default("[]")
  pains               Json?    @default("[]")
  opportunities       Json?    @default("[]")
  strategy            String?
  closingProbability  String?
  nextAction          String?
  missingInfo         Json?    @default("[]")
  rawInput            Json?
  rawOutput           String?
  createdAt           DateTime @default(now())

  messages  MessageSuggestion[]
  feedbacks AgentFeedback[]

  @@map("lead_analyses")
}

model MessageSuggestion {
  id         String         @id @default(cuid())
  leadId     String
  lead       Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  analysisId String?
  analysis   LeadAnalysis?  @relation(fields: [analysisId], references: [id], onDelete: SetNull)
  type       MessageType    @default(INITIAL)
  channel    MessageChannel @default(INSTAGRAM)
  content    String
  status     MessageStatus  @default(DRAFT)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  followups FollowUpTask[]

  @@map("message_suggestions")
}

model FollowUpTask {
  id        String             @id @default(cuid())
  leadId    String
  lead      Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  messageId String?
  message   MessageSuggestion? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  dueDate   DateTime
  status    FollowUpStatus     @default(PENDING)
  notes     String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@map("follow_up_tasks")
}

model AgentFeedback {
  id                  String              @id @default(cuid())
  leadId              String
  lead                Lead                @relation(fields: [leadId], references: [id], onDelete: Cascade)
  analysisId          String?
  analysis            LeadAnalysis?       @relation(fields: [analysisId], references: [id], onDelete: SetNull)
  rating              Int
  problemType         FeedbackProblemType @default(OTHER)
  comment             String?
  expectedImprovement String?
  createdAt           DateTime            @default(now())

  @@map("agent_feedbacks")
}

/// Jornada comercial real do lead — base do sistema de memória/aprendizado (Fase 2).
/// Relação 1:1 com Lead: cada lead tem no máximo um registro de outcome, atualizado
/// progressivamente conforme o funil avança (reunião → proposta → fechamento/perda).
model LeadOutcome {
  id                  String      @id @default(cuid())
  leadId              String      @unique
  lead                Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)

  /// Espelha Lead.status mas é a fonte de verdade para métricas de funil
  /// (permite reclassificar o outcome sem reabrir o lead operacionalmente).
  status              LeadStatus  @default(NEW)
  lossReason          LossReason?

  valorProposta       Decimal?    @db.Decimal(12, 2)
  valorFechado        Decimal?    @db.Decimal(12, 2)
  canalContato        MessageChannel?

  dataPrimeiroContato DateTime?
  dataResposta        DateTime?
  dataReuniao         DateTime?
  dataProposta        DateTime?
  dataFechamento      DateTime?

  observacoes         String?

  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([status])
  @@index([lossReason])
  @@index([canalContato])
  @@index([dataFechamento])
  @@map("lead_outcomes")
}

/// Log de conversas reais com o lead — mensagens efetivamente enviadas
/// (SENT) e respostas recebidas (RECEIVED), por canal. Base da Fase 3.5
/// (Conversas e Respostas Assistidas) e pré-requisito para o North exibir
/// o histórico completo de conversa de um lead sem nova migration.
///
/// Diferença em relação a MessageSuggestion: MessageSuggestion guarda
/// rascunhos sugeridos pela análise inicial do SDR Agent (DRAFT/USED/SENT/
/// RESPONDED/IGNORED) — ainda pode nunca ter sido enviado. LeadConversation
/// guarda o registro factual da troca real de mensagens (enviado/recebido),
/// incluindo sugestões de resposta geradas pelo reply-assistant (marcadas
/// via metadata, ver módulo reply-assistant).
model LeadConversation {
  id        String                 @id @default(cuid())
  leadId    String
  lead      Lead                   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  channel   ConversationChannel    @default(INSTAGRAM)
  direction ConversationDirection
  content   String
  /// Campo livre para metadados que ainda não justificam coluna própria:
  /// ex. { "source": "reply-assistant", "intentAnalysis": "...", "stage": "..." }
  /// Mantém o model extensível sem exigir nova migration para a Fase 4/5.
  metadata  Json?
  createdAt DateTime               @default(now())

  @@index([leadId])
  @@index([channel])
  @@index([direction])
  @@index([createdAt])
  @@map("lead_conversations")
}

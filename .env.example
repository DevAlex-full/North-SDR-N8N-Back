# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Supabase → Settings → Database → Connection String
# Mode: Transaction (com pooler) → DATABASE_URL
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Mode: Session (sem pooler) → DIRECT_URL (usado pelo Prisma migrate)
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT=3333
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Para liberar tudo: *
# Para domínios específicos: https://app.north.com,https://north.com
CORS_ORIGIN=*

# ─── SECURITY ─────────────────────────────────────────────────────────────────
# Chave usada pelo n8n e qualquer cliente no header x-api-key
# Gere com: openssl rand -hex 32
N8N_WEBHOOK_API_KEY=sua-chave-super-secreta-aqui

# ─── REPLY ASSISTANT (Fase 3.5) ────────────────────────────────────────────────
# URL do webhook n8n responsável por gerar a sugestão de resposta ao lead.
# Opcional: se ausente, o backend monta e persiste o contexto normalmente,
# mas não dispara a chamada ao n8n (útil para deploy antes do node existir).
# Exemplo: https://seu-n8n.app.n8n.cloud/webhook/reply-assistant
N8N_REPLY_ASSISTANT_WEBHOOK_URL=
